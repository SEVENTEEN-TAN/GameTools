<Window x:Class="GameTools.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameTools"
        mc:Ignorable="d"
        Title="准星设置" Height="600" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 标题 -->
            <TextBlock Grid.Row="0" Text="准星设置" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <!-- 准星样式 -->
            <GroupBox Grid.Row="1" Header="准星样式" Margin="0,0,0,15">
                <StackPanel Orientation="Vertical" Margin="5">
                    <ComboBox x:Name="StyleComboBox" SelectionChanged="StyleComboBox_SelectionChanged" Margin="0,5,0,0"/>
                    <Canvas x:Name="PreviewCanvas" Height="100" Margin="0,10,0,0" Background="#01000000">
                        <Path x:Name="PreviewCrosshair" Stroke="Red" StrokeThickness="2" Canvas.Left="150" Canvas.Top="50"/>
                    </Canvas>
                </StackPanel>
            </GroupBox>
            
            <!-- 准星大小 -->
            <GroupBox Grid.Row="2" Header="准星大小" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="SizeSlider" Minimum="0.2" Maximum="3.0" Value="1.0" 
                            TickFrequency="0.1" IsSnapToTickEnabled="True" 
                            ValueChanged="SizeSlider_ValueChanged"/>
                    <TextBlock Grid.Column="1" Text="{Binding ElementName=SizeSlider, Path=Value, StringFormat=N1}" 
                               Width="30" TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </GroupBox>
            
            <!-- 准星透明度 -->
            <GroupBox Grid.Row="3" Header="透明度" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="OpacitySlider" Minimum="0.1" Maximum="1.0" Value="0.7" 
                            TickFrequency="0.05" IsSnapToTickEnabled="True" 
                            ValueChanged="OpacitySlider_ValueChanged"/>
                    <TextBlock Grid.Column="1" Text="{Binding ElementName=OpacitySlider, Path=Value, StringFormat=P0}" 
                               Width="40" TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </GroupBox>
            
            <!-- 边框粗细 -->
            <GroupBox Grid.Row="4" Header="边框粗细" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="BorderThicknessSlider" Minimum="0.5" Maximum="10.0" Value="2.0" 
                            TickFrequency="0.5" IsSnapToTickEnabled="True" 
                            ValueChanged="BorderThicknessSlider_ValueChanged"/>
                    <TextBlock Grid.Column="1" Text="{Binding ElementName=BorderThicknessSlider, Path=Value, StringFormat=N1}" 
                               Width="30" TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </GroupBox>
            
            <!-- 填充控制 -->
            <GroupBox Grid.Row="5" Header="填充控制" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal" Margin="5">
                    <CheckBox x:Name="ShowFillCheckBox" Content="显示填充" IsChecked="True" 
                              Checked="ShowFillCheckBox_CheckedChanged" 
                              Unchecked="ShowFillCheckBox_CheckedChanged" 
                              Margin="5"/>
                    <TextBlock Text="(部分准星样式可能不受此设置影响)" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="Gray"/>
                </StackPanel>
            </GroupBox>
            
            <!-- 描边控制 -->
            <GroupBox Grid.Row="6" Header="描边控制" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 是否启用描边 -->
                    <CheckBox Grid.Row="0" x:Name="EnableOutlineCheckBox" Content="启用黑色描边" IsChecked="False" 
                              Checked="EnableOutlineCheckBox_CheckedChanged" 
                              Unchecked="EnableOutlineCheckBox_CheckedChanged" 
                              Margin="5"/>
                    
                    <!-- 描边透明度 -->
                    <Grid Grid.Row="1" Margin="5,10,5,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="描边透明度:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Slider Grid.Column="1" x:Name="OutlineOpacitySlider" Minimum="0.1" Maximum="1.0" Value="0.8" 
                                TickFrequency="0.05" IsSnapToTickEnabled="True" 
                                ValueChanged="OutlineOpacitySlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" Text="{Binding ElementName=OutlineOpacitySlider, Path=Value, StringFormat=P0}" 
                                   Width="40" TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- 描边粗细 -->
                    <Grid Grid.Row="2" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="描边粗细:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Slider Grid.Column="1" x:Name="OutlineThicknessSlider" Minimum="0.5" Maximum="5.0" Value="1.0" 
                                TickFrequency="0.5" IsSnapToTickEnabled="True" 
                                ValueChanged="OutlineThicknessSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" Text="{Binding ElementName=OutlineThicknessSlider, Path=Value, StringFormat=N1}" 
                                   Width="30" TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </GroupBox>
            
            <!-- 准星颜色 -->
            <GroupBox Grid.Row="7" Header="颜色" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 第一行颜色按钮 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <Button Content="红色" Click="RedButton_Click" Width="70" Height="30" Margin="5" Background="#FFCCCC"/>
                        <Button Content="绿色" Click="GreenButton_Click" Width="70" Height="30" Margin="5" Background="#CCFFCC"/>
                        <Button Content="蓝色" Click="BlueButton_Click" Width="70" Height="30" Margin="5" Background="#CCCCFF"/>
                        <Button Content="黄色" Click="YellowButton_Click" Width="70" Height="30" Margin="5" Background="#FFFFCC"/>
                    </StackPanel>
                    
                    <!-- 第二行颜色按钮 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <Button Content="品红" Click="MagentaButton_Click" Width="70" Height="30" Margin="5" Background="#FFCCFF"/>
                        <Button Content="青色" Click="CyanButton_Click" Width="70" Height="30" Margin="5" Background="#CCFFFF"/>
                        <Button Content="白色" Click="WhiteButton_Click" Width="70" Height="30" Margin="5" Background="#FFFFFF"/>
                        <Button Content="橙色" Click="OrangeButton_Click" Width="70" Height="30" Margin="5" Background="#FFDDAA"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- 快捷键说明 -->
            <GroupBox Grid.Row="8" Header="快捷键说明" Margin="0,0,0,15">
                <TextBlock TextWrapping="Wrap" Margin="10">
                    Alt+Z - 显示/隐藏准星<LineBreak/>
                    Alt+X - 打开设置窗口<LineBreak/>
                    Alt+方向键 - 微调准星位置<LineBreak/>
                    Alt+Home - 重置准星到屏幕中心<LineBreak/>
                    Alt+PageUp - 下一个准星样式<LineBreak/>
                    Alt+PageDown - 上一个准星样式<LineBreak/>
                    Alt+加号(+) - 增大准星<LineBreak/>
                    Alt+减号(-) - 缩小准星<LineBreak/>
                    Alt+[ - 降低透明度<LineBreak/>
                    Alt+] - 增加透明度<LineBreak/>
                    Alt+Q - 退出程序
                </TextBlock>
            </GroupBox>
            
            <!-- 按钮区域 -->
            <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="ResetButton" Content="重置默认" Width="100" Height="30" Margin="0,0,10,0" Click="ResetButton_Click"/>
                <Button x:Name="SaveButton" Content="保存" Width="100" Height="30" Click="SaveButton_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window> 