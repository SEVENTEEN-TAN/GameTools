<Window x:Class="GameTools.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameTools"
        mc:Ignorable="d"
        Title="准星设置" Height="700" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 标题 -->
            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="准星设置" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <!-- 准星样式 -->
            <GroupBox Grid.Row="1" Header="准星样式" Margin="0,0,0,15">
                <StackPanel Orientation="Vertical" Margin="5">
                    <ComboBox x:Name="StyleComboBox" SelectionChanged="StyleComboBox_SelectionChanged" Margin="0,5,0,0"/>
                </StackPanel>
            </GroupBox>
            
            <!-- 准星预览 -->
            <GroupBox Header="预览" Margin="5" Grid.Row="1" Grid.Column="1" Grid.RowSpan="2">
                <Grid Background="Transparent">
                    <Canvas x:Name="PreviewCanvas" Width="200" Height="120" Background="#15000000">
                        <!-- 外描边路径 -->
                        <Path x:Name="PreviewOutline" 
                              Stroke="Black" 
                              StrokeThickness="3"
                              Canvas.Left="100" 
                              Canvas.Top="60" 
                              Visibility="Collapsed"/>
                        <!-- 主准星路径 -->
                        <Path x:Name="PreviewCrosshair" 
                              Stroke="Green" 
                              StrokeThickness="1" 
                              Canvas.Left="100" 
                              Canvas.Top="60"/>
                    </Canvas>
                </Grid>
            </GroupBox>
            
            <!-- 准星大小 -->
            <GroupBox Grid.Row="2" Header="准星大小" Margin="0,0,0,15">
                <Grid Margin="5,10,5,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="SizeSlider" Minimum="0.2" Maximum="5.0" Value="1.0" 
                            TickFrequency="0.2" IsSnapToTickEnabled="True" 
                            ValueChanged="SizeSlider_ValueChanged"
                            Height="30"/>
                    <TextBlock Grid.Column="1" Text="{Binding ElementName=SizeSlider, Path=Value, StringFormat=N1}" 
                               Width="40" TextAlignment="Right" VerticalAlignment="Center"
                               FontSize="14" Margin="10,0,0,0"/>
                </Grid>
            </GroupBox>
            
            <!-- 准星透明度 -->
            <GroupBox Grid.Row="3" Grid.ColumnSpan="2" Header="透明度" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="OpacitySlider" Minimum="0.1" Maximum="1.0" Value="0.7" 
                            TickFrequency="0.05" IsSnapToTickEnabled="True" 
                            ValueChanged="OpacitySlider_ValueChanged"/>
                    <TextBlock Grid.Column="1" Text="{Binding ElementName=OpacitySlider, Path=Value, StringFormat=P0}" 
                               Width="40" TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </GroupBox>
            
            <!-- 边框粗细 -->
            <GroupBox Grid.Row="4" Grid.ColumnSpan="2" Header="边框粗细" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="BorderThicknessSlider" Minimum="0.5" Maximum="10.0" Value="2.0" 
                            TickFrequency="0.5" IsSnapToTickEnabled="True" 
                            ValueChanged="BorderThicknessSlider_ValueChanged"/>
                    <TextBlock Grid.Column="1" Text="{Binding ElementName=BorderThicknessSlider, Path=Value, StringFormat=N1}" 
                               Width="30" TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </GroupBox>
            
            <!-- 填充控制 -->
            <GroupBox Grid.Row="5" Grid.ColumnSpan="2" Header="填充控制" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal" Margin="5">
                    <CheckBox x:Name="ShowFillCheckBox" Content="显示填充" IsChecked="True" 
                              Checked="ShowFillCheckBox_CheckedChanged" 
                              Unchecked="ShowFillCheckBox_CheckedChanged" 
                              Margin="5"/>
                    <TextBlock Text="(部分准星样式可能不受此设置影响)" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="Gray"/>
                </StackPanel>
            </GroupBox>
            
            <!-- 准星外轮廓设置 -->
            <GroupBox Grid.Row="6" Grid.ColumnSpan="2" Header="准星轮廓" Margin="0,0,0,15">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="OutlineStyleCheckbox" Content="使用实线轮廓" Margin="5" Grid.Column="1"
                                  Checked="OutlineStyleCheckbox_CheckedChanged" 
                                  Unchecked="OutlineStyleCheckbox_CheckedChanged"/>
                    </Grid>
                    
                    <!-- 描边粗细 -->
                    <Grid Grid.Row="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="描边粗细:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Slider Grid.Column="1" x:Name="OutlineWidthSlider" Minimum="0.5" Maximum="5.0" Value="1.0" 
                                TickFrequency="0.5" IsSnapToTickEnabled="True" 
                                ValueChanged="OutlineWidthSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" Text="{Binding ElementName=OutlineWidthSlider, Path=Value, StringFormat=N1}" 
                                   Width="30" TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- 轮廓颜色选择 -->
                    <Grid Grid.Row="2" Margin="5,10,5,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="轮廓颜色:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="BlackOutlineButton" Content="黑色" Width="60" Height="28" Margin="2" Background="#333333" Foreground="White" Click="BlackOutlineButton_Click"/>
                            <Button x:Name="WhiteOutlineButton" Content="白色" Width="60" Height="28" Margin="2" Background="#FFFFFF" Click="WhiteOutlineButton_Click"/>
                            <Button x:Name="RedOutlineButton" Content="红色" Width="60" Height="28" Margin="2" Background="#FFCCCC" Click="RedOutlineButton_Click"/>
                            <Button x:Name="GreenOutlineButton" Content="绿色" Width="60" Height="28" Margin="2" Background="#CCFFCC" Click="GreenOutlineButton_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </GroupBox>
            
            <!-- 描边控制 -->
            <GroupBox Grid.Row="7" Grid.ColumnSpan="2" Header="描边控制" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 是否启用描边 -->
                    <CheckBox Grid.Row="0" x:Name="EnableOutlineCheckbox" Content="启用黑色描边" IsChecked="False" 
                              Checked="EnableOutlineCheckbox_CheckedChanged" 
                              Unchecked="EnableOutlineCheckbox_CheckedChanged" 
                              Margin="5"/>
                    
                    <!-- 描边透明度 -->
                    <Grid Grid.Row="1" Margin="5,10,5,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="描边透明度:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Slider Grid.Column="1" x:Name="OutlineOpacitySlider" Minimum="0.1" Maximum="1.0" Value="0.8" 
                                TickFrequency="0.05" IsSnapToTickEnabled="True" 
                                ValueChanged="OutlineOpacitySlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" Text="{Binding ElementName=OutlineOpacitySlider, Path=Value, StringFormat=P0}" 
                                   Width="40" TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </GroupBox>
            
            <!-- 准星颜色 -->
            <GroupBox Grid.Row="8" Grid.ColumnSpan="2" Header="颜色" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 第一行颜色按钮 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <Button x:Name="RedButton" Content="红色" Click="RedButton_Click" Width="85" Height="34" Margin="5" Background="#FFCCCC"/>
                        <Button x:Name="GreenButton" Content="绿色" Click="GreenButton_Click" Width="85" Height="34" Margin="5" Background="#CCFFCC"/>
                        <Button x:Name="BlueButton" Content="蓝色" Click="BlueButton_Click" Width="85" Height="34" Margin="5" Background="#CCCCFF"/>
                        <Button x:Name="YellowButton" Content="黄色" Click="YellowButton_Click" Width="85" Height="34" Margin="5" Background="#FFFFCC"/>
                    </StackPanel>
                    
                    <!-- 第二行颜色按钮 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <Button x:Name="MagentaButton" Content="品红" Click="MagentaButton_Click" Width="85" Height="34" Margin="5" Background="#FFCCFF"/>
                        <Button x:Name="CyanButton" Content="青色" Click="CyanButton_Click" Width="85" Height="34" Margin="5" Background="#CCFFFF"/>
                        <Button x:Name="WhiteButton" Content="白色" Click="WhiteButton_Click" Width="85" Height="34" Margin="5" Background="#FFFFFF"/>
                        <Button x:Name="OrangeButton" Content="橙色" Click="OrangeButton_Click" Width="85" Height="34" Margin="5" Background="#FFDDAA"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- 快捷键说明 -->
            <GroupBox Grid.Row="9" Grid.ColumnSpan="2" Header="快捷键说明" Margin="0,0,0,15">
                <TextBlock TextWrapping="Wrap" Margin="10">
                    Alt+Z - 显示/隐藏准星<LineBreak/>
                    Alt+X - 打开设置窗口<LineBreak/>
                    Alt+方向键 - 微调准星位置<LineBreak/>
                    Alt+Home - 重置准星到屏幕中心<LineBreak/>
                    Alt+PageUp - 下一个准星样式<LineBreak/>
                    Alt+PageDown - 上一个准星样式<LineBreak/>
                    Alt+加号(+) - 增大准星<LineBreak/>
                    Alt+减号(-) - 缩小准星<LineBreak/>
                    Alt+[ - 降低透明度<LineBreak/>
                    Alt+] - 增加透明度<LineBreak/>
                    Alt+Q - 退出程序
                </TextBlock>
            </GroupBox>
            
            <!-- 按钮区域 -->
            <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="ResetButton" Content="重置默认" Width="100" Height="30" Margin="0,0,10,0" Click="ResetButton_Click"/>
                <Button x:Name="SaveButton" Content="保存" Width="100" Height="30" Click="SaveButton_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window> 